generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  OWNER
  MANAGER
  RECEPTION
}

enum ZoneKey {
  WINDOW
  CENTER
  ROOF
}

enum TableShape {
  ROUND
  SQUARE
  RECTANGLE
}

enum ReservationStatus {
  DRAFT
  HOLD
  PAYMENT_PENDING
  PAYMENT_REVIEW
  CONFIRMED
  CHANGE_PENDING
  CANCELLED
  COMPLETED
  NO_SHOW
  EXPIRED
}

enum ReservationSource {
  ONLINE
  GUEST
  ADMIN_MANUAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REVIEW
  REFUND_PENDING
  REFUNDED
}

enum PaymentMethod {
  MOCK
  ZARINPAL
  MANUAL
}

enum RefundStatus {
  NONE
  PENDING
  DONE
}

enum OtpPurpose {
  LOGIN
  GUEST_ACCESS
  RESERVATION_CHANGE
}

enum SmsType {
  OTP
  CONFIRMATION
  REMINDER
  CANCELLATION
  CHANGE
  NOT_CONFIRMED
}

model User {
  id           String        @id @default(cuid())
  phone        String        @unique
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         AdminRole @default(RECEPTION)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model OtpCode {
  id         String     @id @default(cuid())
  phone      String
  code       String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([phone, purpose])
}

model CafeTable {
  id             String             @id @default(cuid())
  code           String             @unique
  displayNumber  String
  zone           ZoneKey
  shape          TableShape
  capacity       Int
  minGuests      Int                @default(1)
  maxGuests      Int
  isActive       Boolean            @default(true)
  x              Float
  y              Float
  width          Float              @default(82)
  height         Float              @default(58)
  rotation       Float              @default(0)
  chairs         Json?
  description    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  reservations   ReservationTable[]
  blockedClosures Closure[]
  connectionsA   TableConnection[]  @relation("ConnectionA")
  connectionsB   TableConnection[]  @relation("ConnectionB")
}

model TableConnection {
  id        String    @id @default(cuid())
  tableAId  String
  tableBId  String
  tableA    CafeTable @relation("ConnectionA", fields: [tableAId], references: [id], onDelete: Cascade)
  tableB    CafeTable @relation("ConnectionB", fields: [tableBId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([tableAId, tableBId])
}

model Reservation {
  id                 String              @id @default(cuid())
  trackingCode       String              @unique
  userId             String?
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerName       String
  customerPhone      String
  guestCount         Int
  startAt            DateTime
  endAt              DateTime
  durationMinutes    Int
  status             ReservationStatus   @default(HOLD)
  source             ReservationSource   @default(ONLINE)
  holdExpiresAt      DateTime?
  pricePerGuest      Int
  totalAmount        Int
  paidAmount         Int                 @default(0)
  refundStatus       RefundStatus        @default(NONE)
  originalReservationId String?
  originalReservation   Reservation?     @relation("ReservationChange", fields: [originalReservationId], references: [id], onDelete: SetNull)
  changeRequests     Reservation[]       @relation("ReservationChange")
  notes              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tables             ReservationTable[]
  payments           Payment[]
  invoice            Invoice?

  @@index([customerPhone])
  @@index([startAt, endAt])
  @@index([status])
}

model ReservationTable {
  id            String      @id @default(cuid())
  reservationId String
  tableId       String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  table         CafeTable   @relation(fields: [tableId], references: [id], onDelete: Restrict)

  @@unique([reservationId, tableId])
  @@index([tableId])
}

model Payment {
  id            String        @id @default(cuid())
  reservationId String
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  amount        Int
  status        PaymentStatus @default(PENDING)
  method        PaymentMethod @default(MOCK)
  provider      String        @default("mock")
  authority     String?
  refId         String?
  isMock        Boolean       @default(true)
  rawResponse   Json?
  createdAt     DateTime      @default(now())
  verifiedAt    DateTime?

  @@index([reservationId])
}

model Invoice {
  id            String      @id @default(cuid())
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  number        String      @unique
  totalAmount   Int
  createdAt     DateTime    @default(now())
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkingHour {
  id        String  @id @default(cuid())
  dayOfWeek Int
  opensAt   String
  closesAt  String
  isClosed  Boolean @default(false)

  @@unique([dayOfWeek])
}

model Closure {
  id        String     @id @default(cuid())
  title     String
  date      DateTime
  startTime String?
  endTime   String?
  zone      ZoneKey?
  tableId   String?
  table     CafeTable? @relation(fields: [tableId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime   @default(now())

  @@index([date])
}

model SmsLog {
  id        String   @id @default(cuid())
  phone     String
  type      SmsType
  message   String
  status    String   @default("MOCK_SENT")
  createdAt DateTime @default(now())
}
