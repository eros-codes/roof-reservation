# PostgreSQL از قبل روی سیستم خودت نصب است. فقط این آدرس را با پسورد واقعی خودت تنظیم کن.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/roof_reservation?schema=public"

PORT=3000
NODE_ENV=development
APP_URL="http://localhost:3000"
JWT_SECRET="change-this-super-secret"
ADMIN_JWT_SECRET="change-this-admin-secret"

# ادمین اولیه seed
SEED_ADMIN_EMAIL="admin@roof.local"
SEED_ADMIN_PASSWORD="Admin123456"
SEED_ADMIN_NAME="Roof Owner"

# Mock services
SMS_MODE="console"
PAYMENT_MODE="mock"
